# Copy to .env and fill in. Never commit .env.

BASE_URL=https://copilot.asksam.com.au
LOGIN_URL=https://copilot.asksam.com.au/sign-in
DASHBOARD_URL=https://dashboard.asksam.com.au
EXPERT_DASHBOARD_URL=https://dashboard.asksam.com.au/expert/dashboard
COPILOT_HOME_URL=https://copilot.asksam.com.au/clinical/home

# Clerk test-mode clinician email (OTP code 424242 in test mode)
TEST_EMAIL=
TEST_PASSWORD=

# Optional: separate email for letter-template module tests
LETTER_TEMPLATE_TEST_EMAIL=

GOOGLE_APPS_SCRIPT_URL=
EMAIL_WEB_APP_URL=
# Comma-separated failure report recipients (Google Apps Script MailApp)
REPORT_RECIPIENTS=arti@shunyalabs.ai,sumit@shunyalabs.ai,yamini@shunyalabs.ai,saira@unitedwecare.com,sb@shunyalabs.ai,ritu@shunyalabs.ai,ayushbar@shunyalabs.ai,ravulamk@shunyalabs.ai

# Optional
GOOGLE_SHEETS_URL=
DASHBOARD_PAGES_URL=https://saira-uwc.github.io/asksam-datascience-automation/

# RAG API smoke tests (rag.uwc.world)
RAG_API_BASE_URL=https://rag.uwc.world
RAG_API_USER_ID=automation-smoke
RAG_API_SESSION_ID=smoke-session
RAG_API_REGISTERED_ID=automation-smoke
RAG_API_GEN_CHAT_MESSAGE=ping
RAG_API_GEN_CHAT_CLASSIFY=general

# Clinical Notes API — base URL filled by discover:clinical-notes-apis (prod Copilot network capture)
CLINICAL_NOTES_API_BASE_URL=

# Stella / NeoGraph — base URLs filled by discover:assistant-apis
STELLA_API_BASE_URL=
NEOGRAPH_API_BASE_URL=

# Optional: AU proxy for Stripe geo-restricted signup test
# AU_PROXY_SERVER=
# AU_PROXY_USERNAME=
# AU_PROXY_PASSWORD=
